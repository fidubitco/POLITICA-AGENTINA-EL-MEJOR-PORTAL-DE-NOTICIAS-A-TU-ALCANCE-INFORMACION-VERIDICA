{
  "name": "ai-gateway",
  "version": "1.0.0",
  "description": "Zero-cost AI Gateway with local LLMs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:build": "docker build -t politica-ai-gateway .",
    "docker:run": "docker run -p 4000:4000 --env-file .env politica-ai-gateway"
  },
  "dependencies": {
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "axios": "^1.6.2",
    "socks-proxy-agent": "^8.0.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
