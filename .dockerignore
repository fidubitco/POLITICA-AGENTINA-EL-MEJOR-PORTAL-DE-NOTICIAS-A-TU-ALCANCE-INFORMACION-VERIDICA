# ============================================================================
# POLÍTICA ARGENTINA - Docker Ignore Configuration
# Optimize build context and reduce image size
# ============================================================================

# Dependencies
node_modules/
npm-debug.log
yarn-error.log
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock

# Next.js build outputs
.next/
out/
dist/
build/

# Testing
coverage/
.nyc_output/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
__mocks__/
jest.config.js
cypress/

# Environment files (keep .env.example)
.env
.env.*
!.env.example

# IDE and editor files
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Version control
.git/
.gitignore
.gitattributes
.github/

# CI/CD
.gitlab-ci.yml
.travis.yml
.circleci/

# Documentation
*.md
!README.md
docs/
.docusaurus/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Cache directories
.cache/
.parcel-cache/
.turbo/
tmp/
temp/
*.tmp

# Development files
nodemon.json
.prettierrc
.eslintrc*
.editorconfig

# Docker files (don't copy these into the container)
docker-compose*.yml
Dockerfile*
!Dockerfile
.dockerignore

# Prisma
prisma/migrations/
prisma/*.db
prisma/*.db-journal
prisma/dev.db*

# Backup files
*.bak
*.backup
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Misc
.vercel/
.railway/
